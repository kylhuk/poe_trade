{
  "scenarios": ["live-readonly", "live-allowlisted-mutation"],
  "targets": {
    "frontend_ui_public": "https://poe.lama-lan.ch",
    "backend_api_remote": "https://api.poe.lama-lan.ch",
    "backend_api_local": "http://127.0.0.1:8080",
    "frontend_runtime_local": "http://127.0.0.1:5173"
  },
  "commands": {
    "public_unauthenticated_check": "curl -i https://api.poe.lama-lan.ch/healthz",
    "protected_readonly_check": "curl -i -H \"Authorization: Bearer $POE_API_OPERATOR_TOKEN\" https://api.poe.lama-lan.ch/api/v1/ops/services",
    "allowlisted_mutation_check": "curl -i -X POST -H \"Authorization: Bearer $POE_API_OPERATOR_TOKEN\" https://api.poe.lama-lan.ch/api/v1/actions/services/market_harvester/restart",
    "backend_start_local": "make up",
    "frontend_start_local": "cd frontend && VITE_API_BASE_URL=http://127.0.0.1:8080 npm run dev"
  },
  "protection_mechanisms": {
    "default_api_base": "https://api.poe.lama-lan.ch",
    "mutation_allowlist": "restart-only",
    "auth_requirement": "Bearer operator-token for /api/v1/ops/*, /api/v1/ml/*, /api/v1/actions/*",
    "cors_restriction": "POE_API_CORS_ORIGINS (no wildcard)"
  },
  "safety_proof": "Live checks are explicitly separated from QA by using the production hostnames. The frontend defaults to the live API, but QA runs override this via environment variables. Protected routes require a valid bearer token."
}
