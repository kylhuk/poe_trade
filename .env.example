POE_CLICKHOUSE_URL=http://127.0.0.1:8123
POE_CLICKHOUSE_INTERNAL_URL=http://clickhouse:8123
POE_CLICKHOUSE_DATABASE=poe_trade
POE_CLICKHOUSE_USER=poe_ingest
POE_CLICKHOUSE_PASSWORD=poe_ingest

POE_REALMS=pc
POE_OAUTH_CLIENT_ID=
POE_OAUTH_CLIENT_SECRET=
# OAuth credentials are required for `market_harvester`; prefer secret file paths in production.
# Optional secret file path (preferred for production):
# POE_OAUTH_CLIENT_SECRET_FILE=/run/secrets/poe_oauth_client_secret
POE_OAUTH_CLIENT_SECRET_FILE=
POE_OAUTH_GRANT_TYPE=client_credentials
POE_OAUTH_SCOPE=service:psapi service:cxapi
# Account OAuth (authorization_code + PKCE) for /api/v1/auth/login.
# Must exactly match the redirect URI registered on https://www.pathofexile.com/my-account/applications.
POE_ACCOUNT_REDIRECT_URI=
POE_ACCOUNT_OAUTH_SCOPE=account:profile account:stashes
POE_API_BASE_URL=https://api.pathofexile.com

POE_USER_AGENT=poeml/1.0.0 (contact: gaffe_nearest606@bananabeer.org) Love you!

POE_ENABLE_PSAPI=true
POE_ENABLE_CXAPI=false
POE_PSAPI_POLL_SECONDS=30
POE_CXAPI_BACKFILL_HOURS=168
POE_CXAPI_HOUR_OFFSET_SECONDS=15
POE_REFRESH_REFS_MINUTES=5
POE_SCAN_MINUTES=5
POE_RAW_PSAPI_TTL_DAYS=21
POE_RAW_CX_TTL_DAYS=365
POE_SILVER_TTL_DAYS=90
POE_ML_V3_SERVING_ENABLED=0
POE_ML_V3_TRAINER_ENABLED=0

# Legacy/private workflow alias. Not used by active services.
POE_STASH_TRIGGER_TOKEN=change-me
POE_STASH_API_PATH=public-stash-tabs
# Use account-stash-tabs only when OAuth has account:* access.
# public-stash-tabs works with service:psapi tokens.

# Deprecated compatibility-only settings. These no longer define canonical runtime behavior.
# POE_CHECKPOINT_DIR=.state/cursors
# POE_CURSOR_DIR=.state/cursors
# POE_CURSOR_FILE=.state/cursor
# POE_LEAGUES=Synthesis
# POE_STASH_BOOTSTRAP_UNTIL_LEAGUE=Keepers
# POE_STASH_BOOTSTRAP_FROM_BEGINNING=true

CH_HOST=clickhouse
CH_PORT=8123
CH_DATABASE=poe_trade
CH_USER=poe_ingest
CH_PASSWORD=poe_ingest
